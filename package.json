    "framer-motion": "^12.40.0",
    "json2csv": "^6.0.0-alpha.2",
    "lottie-react": "^2.4.1",
    "lucide-react": "^1.18.0",
    "multer": "^2.1.1",
    "pdfkit": "^0.19.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^6.30.4",
    "react-toastify": "^11.1.0",
    "sweetalert2": "^11.26.25",
    "swiper": "^12.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
