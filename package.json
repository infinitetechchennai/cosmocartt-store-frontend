{
  "name": "cosmocart-store",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "generate:sitemap": "node scripts/generate-sitemap.js",
    "build:admin": "cd cosmocartt-admin && npm install && npm run build",
    "copy:admin": "rm -rf dist/admin && mkdir -p dist/admin && cp -R cosmocartt-admin/dist/* dist/admin/",
    "vercel-build": "npm install && npm run build && npm run build:admin && npm run copy:admin",
    "preview": "vite preview"
  },
