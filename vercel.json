{
    "buildCommand": "npm run vercel-build",
    "outputDirectory": "dist",
    "rewrites": [
        {
            "source": "/admin",
            "destination": "/admin/index.html"
        },
        {
            "source": "/admin/(.*)",
            "destination": "/admin/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}